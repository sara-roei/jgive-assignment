<%= form_with model: [campaign, donation], class: "donation-form" do |f| %>

  <h2>פרטי התרומה שלי</h2>

  <% if donation.errors.any? %>
    <div class="form-errors">
      <% donation.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <%# One-time / Recurring %>
  <div class="form-group">
    <div class="radio-group">
      <%= f.radio_button :recurring, false, checked: !donation.recurring, id: "recurring_false" %>
      <%= f.label :recurring, "תרומה חד-פעמית", for: "recurring_false" %>

      <%= f.radio_button :recurring, true, checked: donation.recurring, id: "recurring_true" %>
      <%= f.label :recurring, "הוראת קבע", for: "recurring_true" %>
    </div>
  </div>

  <%# Preset amounts %>
  <div class="form-group">
    <div class="preset-amounts">
      <% [
        { value: 180, label: "נטיעת עץ" },
        { value: 260, label: "נטיעת 2 עצים" },
        { value: 360, label: "נטיעת 3 עצים" },
        { value: 1800, label: "בונים מרחב לילדים" },
        { value: 5000, label: "בוני הגן הכתום" }
      ].each do |option| %>
        <button type="button" class="preset-amount" data-amount="<%= option[:value] %>">
          <span class="preset-value"><%= option[:value] %> &#8362;</span>
          <span class="preset-label"><%= option[:label] %></span>
        </button>
      <% end %>
      <button type="button" class="preset-amount" data-amount="custom">
        <span class="preset-label">סכום אחר</span>
      </button>
    </div>

    <%= f.number_field :amount, min: 1, step: 1, placeholder: "הזינו סכום", class: "amount-input", id: "donation_amount" %>
  </div>

  <%# Dedication %>
  <div class="form-group">
    <label class="checkbox-label">
      <input type="checkbox" id="dedication-toggle">
      הקדשת תרומה
    </label>
    <div class="dedication-field" style="display: none;">
      <%= f.text_area :dedication, placeholder: "הקדשה", rows: 3 %>
    </div>
  </div>

  <%# Display Preference %>
  <div class="form-group">
    <label>אני רוצה שבעמוד הפרויקט יופיע:</label>
    <%= f.select :display_preference,
      [
        ["השם שלי וסכום התרומה", "show_name_and_amount"],
        ["השם שלי בלבד", "show_name_only"],
        ["סכום התרומה בלבד", "show_amount_only"]
      ],
      {}, class: "display-preference-select" %>
  </div>

  <%# Donor Name %>
  <div class="form-group">
    <%= f.label :donor_name, "שם התורם/ת" %>
    <%= f.text_field :donor_name, placeholder: "שם מלא", class: "text-input" %>
  </div>

  <%# Submit %>
  <div class="form-group">
    <%= f.submit "תרמו עכשיו", class: "submit-button" %>
  </div>

<% end %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var amountField = document.getElementById('donation_amount');

    document.querySelectorAll('.preset-amount').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.preset-amount').forEach(function(b) { b.classList.remove('selected'); });
        btn.classList.add('selected');

        if (btn.dataset.amount === 'custom') {
          amountField.value = '';
          amountField.focus();
        } else {
          amountField.value = btn.dataset.amount;
        }
      });
    });

    document.getElementById('dedication-toggle').addEventListener('change', function() {
      document.querySelector('.dedication-field').style.display = this.checked ? 'block' : 'none';
    });
  });
</script>
